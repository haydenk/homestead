#!/usr/bin/env bash
#MISE description="Build .deb, .rpm, and .apk packages with nfpm (requires homestead binary in cwd)"
set -euo pipefail

: "${GOARCH:=$(go env GOARCH)}"
VERSION=$(git describe --tags --always 2>/dev/null || echo "0.1.0")
export GOARCH VERSION

mkdir -p dist

for PKG in deb rpm apk; do
  echo "  packaging ${PKG} (linux/${GOARCH})…"
  nfpm package --config nfpm.yaml --packager "${PKG}" --target dist/
done

echo ""
echo "Packages written to dist/:"
ls -lh dist/
